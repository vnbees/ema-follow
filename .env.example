# Exchange selector: bitget | binance
EXCHANGE=bitget

# Bitget API credentials
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# Binance USDT-M Futures (mainnet)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_API_BASE=https://fapi.binance.com

# Trading
SYMBOL=SUIUSDT
ORDER_MARGIN_PCT=0.5
ORDER_MARGIN_MIN_USDT=1
LEGACY_MARGIN_USDT=5
MARGIN_MODE=crossed
LEVERAGE=10
TRADING_ENABLED=true
MAX_OPEN_SYMBOLS=20
PAIR_PROFIT_TARGET_PCT=2

# Order Flow Imbalance (SOLUSDT only, 1m realtime display)
OFI_SYMBOL=SOLUSDT
OFI_INTERVAL_MINUTES=1
OFI_SPIKE_THRESHOLD=1.5
OFI_HISTORY_CANDLES=10
OFI_REALTIME_REFRESH_SEC=1
OFI_IMBALANCE_STRONG_PCT=200
OFI_IMBALANCE_EXTREME_PCT=300
OFI_BOOK_TICK_RANGE=8
OFI_BOOK_STRONG_PCT=150
OFI_DELTA_SPIKE_MIN=1.5
OFI_EARLY_ENTRY_SEC=5

# RSI strategy (5m)
GRANULARITY=5m
INTERVAL_MINUTES=5
CANDLE_LIMIT=200
RSI_PERIOD=14
RSI_LONG_ENTRY=25
RSI_LONG_EXIT=75
RSI_SHORT_ENTRY=75
RSI_SHORT_EXIT=25

PROFIT_TARGET_PCT=0

# Margin guard (maintenance margin / equity)
MARGIN_GUARD_ENABLED=true
MARGIN_MAINT_OK_PCT=15
MARGIN_MAINT_WARN_PCT=20
MARGIN_MAINT_HIGH_PCT=25
MARGIN_MAINT_CRITICAL_PCT=35
MARGIN_MAINT_DELEVERAGE_PCT=30
MARGIN_HIGH_TP_PCT=1
MARGIN_DEPOSIT_TARGET_PCT=18
MARGIN_ELEVATED_CYCLE_LIMIT=3
MARGIN_HIGH_CYCLE_LIMIT=2
MARGIN_IMPROVEMENT_PCT=0.3

# App
WEB_PORT=8080
DATABASE_PATH=data/bot.db
