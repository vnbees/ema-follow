# Bitget API credentials (required for trading and balance)
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# Trading
SYMBOL=SUIUSDT
ORDER_SIZE_USDT=5
MARGIN_MODE=crossed
LEVERAGE=5
TRADING_ENABLED=false

# Order Flow Imbalance (ETHUSDT only, 1m realtime display)
OFI_SYMBOL=ETHUSDT
OFI_INTERVAL_MINUTES=1
OFI_SPIKE_THRESHOLD=1.5
OFI_HISTORY_CANDLES=10
OFI_REALTIME_REFRESH_SEC=1

PROFIT_TARGET_PCT=1

# App
WEB_PORT=8080
DATABASE_PATH=data/bot.db
