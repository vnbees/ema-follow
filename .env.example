# Bitget API credentials (required for trading and balance)
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# Trading
SYMBOL=SUIUSDT
ORDER_SIZE_USDT=5
MARGIN_MODE=crossed
LEVERAGE=10
TRADING_ENABLED=true

# Order Flow Imbalance (SOLUSDT only, 1m realtime display)
OFI_SYMBOL=SOLUSDT
OFI_INTERVAL_MINUTES=1
OFI_SPIKE_THRESHOLD=1.5
OFI_HISTORY_CANDLES=10
OFI_REALTIME_REFRESH_SEC=1
OFI_IMBALANCE_STRONG_PCT=200
OFI_IMBALANCE_EXTREME_PCT=300
OFI_BOOK_TICK_RANGE=8
OFI_BOOK_STRONG_PCT=150
OFI_DELTA_SPIKE_MIN=1.5
OFI_EARLY_ENTRY_SEC=5
# Ichimoku M15 trend following (replaces EMA+SAR trading)
GRANULARITY=15m
INTERVAL_MINUTES=15
CANDLE_LIMIT=200
ICHIMOKU_TENKAN=9
ICHIMOKU_KIJUN=26
ICHIMOKU_SENKOU_B=52
ICHIMOKU_DISPLACEMENT=26
ICHIMOKU_SL_TICKS=8
ICHIMOKU_RETEST_TOLERANCE_TICKS=3
ICHIMOKU_PARTIAL_TP_RATIO=0.5

PROFIT_TARGET_PCT=1

# App
WEB_PORT=8080
DATABASE_PATH=data/bot.db
